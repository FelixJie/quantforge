# QuantForge Configuration
QUANTFORGE_ENV=development

# Tushare (optional, for richer A-share data)
TUSHARE_TOKEN=

# Database (default: SQLite)
DATABASE_URL=sqlite:///data/quantforge.db

# iFinD (同花顺) 数据接口凭证 —— 复制本文件为 .env 并填入
# 需先安装 iFinDPy SDK（随同花顺 iFinD 客户端分发，非公网 PyPI）；
# SDK 装好且凭证有效后，行情/估值自动切到 iFinD，否则回退新浪/腾讯。
IFIND_USER=
IFIND_PWD=

# LLM 密钥 —— 从源码移出，改由环境变量注入
# DeepSeek LLM 密钥
DEEPSEEK_API_KEY=
# MiniMax LLM 密钥（默认主用 provider）
MINIMAX_API_KEY=

# 全市场研报库同步（「信息→研报」板块）：开机库空补近一年全量，之后每小时增量入库。
# 默认关闭——东财 reportapi 在部分环境间歇被代理劫持，确认网络可达后置 1 开启。
QF_ENABLE_REPORT_SYNC=1
# 研报同步间隔（小时），默认 1
QF_REPORT_SYNC_INTERVAL_HOURS=1

# JWT 签名密钥 —— 生产环境必须设置为一个随机长字符串，
# 否则每次重启服务都会重新生成临时密钥，导致所有已签发 token 失效。
# 生成方式：python -c "import secrets;print(secrets.token_urlsafe(48))"
QF_JWT_SECRET=
