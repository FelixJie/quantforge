# QuantForge Configuration
QUANTFORGE_ENV=development

# Tushare (optional, for richer A-share data)
TUSHARE_TOKEN=

# Database (default: SQLite)
DATABASE_URL=sqlite:///data/quantforge.db

# iFinD (同花顺) 数据接口凭证 —— 复制本文件为 .env 并填入
# 需先安装 iFinDPy SDK（随同花顺 iFinD 客户端分发，非公网 PyPI）；
# SDK 装好且凭证有效后，行情/估值自动切到 iFinD，否则回退新浪/腾讯。
IFIND_USER=
IFIND_PWD=
