.netlify

# 本地数据库文件（缓存库，体积大且随机器变化）
data/*.db
data/*.db-shm
data/*.db-wal

# 敏感数据（含用户密码哈希、账户信息、本地交易状态，不得入库）
data/users.json
data/accounts.json
data/paper_state.json
# JWT 签名密钥（缺省 QF_JWT_SECRET 时自动落盘，每机一份，不得入库/同步）
data/.jwt_secret

# 根目录一次性临时脚本（部署/调试残留）
/_*.py

# 根目录临时产物（探测输出、验证结果等）
/_*.json
/all_skus.txt
/rev_tmp.json
/col_diag.txt
/missing_skus.txt

# 诊断输出（*_diag.txt：llm_diag.txt / col_diag.txt 等运行期诊断转储）
*_diag.txt

# src 下一次性中间产物（选股/策略快照 JSON，非源码）
src/_*.json

# src 下本地缓存库与缓存目录（cache.db / cache/，体积大、随机器变化，绝不入库）
src/data/

# 生成的分析报告（运行期产物）
/reports/

# 纷传公众号抓取：runtime token/缓存（token.txt 含敏感 JWT，绝不入库）
fenchuan_blog/token.txt
fenchuan_blog/cache.json
fenchuan_blog/data/
fenchuan_blog/_probe_*.json
fenchuan_blog/__pycache__/

