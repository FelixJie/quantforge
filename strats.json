[{"id":"S001","name":"dual_ma","source":"builtin","display_name":"双均线策略","class_name":"DualMAStrategy","module_path":"strategies.examples.dual_ma_strategy.DualMAStrategy","description":"Dual moving average crossover (trend following)","parameters":["fast_period","slow_period","symbol","exchange"],"params_desc":{"fast_period":"快均线周期（默认10日）","slow_period":"慢均线周期（默认30日）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["趋势跟随","均线","经典","入门"],"logic":"快均线上穿慢均线买入（金叉），下穿卖出（死叉）","suitable":"单边上涨趋势行情","risk":"低","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":["ma_golden_cross"]},{"id":"S002","name":"rsi_mean_revert","source":"builtin","display_name":"RSI均值回归","class_name":"RSIMeanRevertStrategy","module_path":"strategies.examples.rsi_mean_revert.RSIMeanRevertStrategy","description":"RSI均值回归 — 超跌买入、超涨卖出。RSI<30时建仓，RSI>70时平仓，同时设有5%止损保护。适合震荡行情。","parameters":["symbol","rsi_period","oversold","overbought","stop_loss"],"params_desc":{"rsi_period":"RSI计算周期（默认14）","oversold":"超卖阈值（默认30）","overbought":"超买阈值（默认70）"},"category":"mean_reversion","category_label":"均值回归","category_color":"#22c55e","category_icon":"repeat","tags":["均值回归","RSI","振荡","止损"],"logic":"RSI < 30 超跌买入，RSI > 70 超涨卖出，内置5%止损","suitable":"震荡横盘行情","risk":"中低","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":["shrink_pullback"]},{"id":"S003","name":"bollinger_breakout","source":"builtin","display_name":"布林带突破","class_name":"BollingerBreakoutStrategy","module_path":"strategies.examples.bollinger_breakout.BollingerBreakoutStrategy","description":"布林带突破策略 — 价格突破上轨时买入（趋势跟随），跌回中轨时卖出获利了结，并设7%止损。适合单边趋势行情。","parameters":["symbol","bb_period","bb_std","stop_loss"],"params_desc":{"period":"布林带周期（默认20）","std_dev":"标准差倍数（默认2）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["趋势跟随","布林带","突破","止损"],"logic":"价格突破布林带上轨买入，回落中轨卖出，内置7%止损","suitable":"强趋势行情，板块轮动期","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":["volume_breakout"]},{"id":"S004","name":"macd","source":"builtin","display_name":"MACD趋势跟随","class_name":"MACDStrategy","module_path":"strategies.examples.macd_strategy.MACDStrategy","description":"MACD趋势跟随 — MACD线上穿信号线时做多，下穿时平仓。经典动量指标，捕捉中期趋势，默认参数(12,26,9)。","parameters":["symbol","fast_period","slow_period","signal_period"],"params_desc":{"fast":"快线周期（默认12）","slow":"慢线周期（默认26）","signal":"信号线周期（默认9）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["趋势跟随","MACD","动量","经典"],"logic":"MACD线上穿信号线做多，下穿平仓，默认参数(12,26,9)","suitable":"中期趋势行情，避免高频震荡","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S005","name":"turtle_breakout","source":"builtin","display_name":"海龟突破系统","class_name":"TurtleBreakoutStrategy","module_path":"strategies.examples.turtle_breakout.TurtleBreakoutStrategy","description":"海龟突破策略 — 经典趋势跟踪系统，N日最高价突破买入，M日最低价破位卖出，ATR动态调整止损位，适合单边行情，是量化趋势策略的经典原型。","parameters":["symbol","entry_period","exit_period","atr_multiplier"],"params_desc":{"entry_period":"突破周期N（默认20日）","exit_period":"退出周期M（默认10日）","atr_multiplier":"ATR止损倍数（默认2.0）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["海龟","突破","趋势跟随","ATR","止损","经典"],"logic":"N日最高价突破买入，M日最低价破位止损，ATR动态调整仓位","suitable":"强趋势行情，品种流动性好","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S006","name":"keltner_channel","source":"builtin","display_name":"肯特纳通道策略","class_name":"KeltnerChannelStrategy","module_path":"strategies.examples.keltner_channel.KeltnerChannelStrategy","description":"肯特纳通道策略 — 以EMA为中轨，ATR为宽度构建动态波动通道。价格触及下轨超卖时买入，回归中轨时止盈出场。支持长期趋势过滤，仅在牛市方向上做多，避免逆势交易。","parameters":["symbol","ema_period","atr_period","multiplier","trend_filter"],"params_desc":{"ema_period":"EMA周期（默认20）","atr_period":"ATR周期（默认14）","multiplier":"通道宽度倍数（默认2.0）","trend_filter":"启用200日趋势过滤"},"category":"mean_reversion","category_label":"均值回归","category_color":"#22c55e","category_icon":"repeat","tags":["肯特纳","通道","ATR","EMA","均值回归"],"logic":"价格触及EMA±ATR×倍数下轨买入，回归EMA中轨时卖出，支持长期趋势过滤","suitable":"震荡偏多行情，避免熊市使用","risk":"中低","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S007","name":"volume_price_breakout","source":"builtin","display_name":"量价共振突破","class_name":"VolumePriceBreakoutStrategy","module_path":"strategies.examples.volume_price_breakout.VolumePriceBreakoutStrategy","description":"量价共振突破策略 — 同时满足价格突破N日高点和成交量放大N倍两个条件才开仓，有效过滤假突破信号。价格回落均线时止盈出场，内置硬止损控制回撤。特别适合A股放量突破的主升浪行情。","parameters":["symbol","lookback","vol_multiplier","stop_loss"],"params_desc":{"lookback":"回溯周期（默认20）","vol_multiplier":"放量倍数（默认1.5×）","stop_loss":"硬止损比例（默认7%）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["量价","突破","共振","放量","趋势跟随"],"logic":"价格突破N日高点且成交量超过均量vol_mult倍，双重确认才入场","suitable":"放量突破的主升浪，筛选真实启动信号","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S008","name":"chandelier_exit","source":"builtin","display_name":"吊灯止损趋势跟踪","class_name":"ChandelierExitStrategy","module_path":"strategies.examples.chandelier_exit.ChandelierExitStrategy","description":"吊灯止损趋势跟踪 — 以最高价的ATR倍数设定动态追踪止损位，止损只升不降，让盈利奔跑同时严格控制回撤。价格上穿EMA时入场，跌破止损线时出场。适合波动率稳定的强势趋势个股，夏普比率通常优于固定止损策略。","parameters":["symbol","ema_period","atr_period","multiplier"],"params_desc":{"ema_period":"入场EMA周期（默认21）","atr_period":"ATR周期（默认22）","multiplier":"止损ATR倍数（默认3.0）"},"category":"trend_following","category_label":"趋势跟随","category_color":"#3b82f6","category_icon":"trending-up","tags":["吊灯止损","追踪止损","ATR","EMA","让利润奔跑"],"logic":"EMA确认趋势后入场，止损线 = 最高价 - N×ATR，随行情上移只升不降","suitable":"中长期趋势行情，持有期长","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S009","name":"grid_trading","source":"builtin","display_name":"网格交易策略","class_name":"GridTradingStrategy","module_path":"strategies.examples.grid_trading.GridTradingStrategy","description":"网格交易策略 — 以中心价格为基准划定等间距网格，价格下穿网格线时买入，上穿时卖出，在震荡行情中持续积累差价收益。适合波动率稳定的横盘个股。","parameters":["symbol","grid_spacing","grid_levels","lot_size"],"params_desc":{"grid_spacing":"网格间距（默认2%）","grid_levels":"网格层数（默认上下各5层）","lot_size":"每格交易手数（默认100股）"},"category":"mean_reversion","category_label":"均值回归","category_color":"#22c55e","category_icon":"repeat","tags":["网格","震荡","均值回归","自动","套利"],"logic":"以中心价为基准划分等间距网格，触及下格买入，上格卖出，持续积累差价","suitable":"横盘震荡、波动率稳定的个股，不适合单边趋势","risk":"低（需防趋势性下跌出网格）","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S010","name":"adaptive_momentum","source":"builtin","display_name":"自适应动量策略","class_name":"AdaptiveMomentumStrategy","module_path":"strategies.examples.adaptive_momentum.AdaptiveMomentumStrategy","description":"自适应动量策略 — 自动识别市场状态：低波动率趋势行情用均线跟随，高波动率震荡行情切换为RSI均值回归，智能适应不同市场环境。","parameters":["symbol","vol_window","vol_threshold","fast_period","slow_period"],"params_desc":{"vol_threshold":"波动率切换阈值（默认30%年化）","vol_window":"波动率计算窗口（默认20）"},"category":"adaptive","category_label":"自适应","category_color":"#a855f7","category_icon":"cpu","tags":["自适应","状态切换","AI","多信号"],"logic":"实时检测波动率判断趋势/震荡状态，低波动用均线趋势，高波动切换RSI回归","suitable":"全天候，自动适应不同行情","risk":"中","has_backtest":true,"has_screener":false,"has_yaml_signal":false,"yaml_links":[]},{"id":"S011","name":"ensemble_voting","source":"builtin","display_name":"集成投票策略","class_name":"EnsembleVotingStrategy","module_path":"strategies.examples.ensemble_voting.EnsembleVotingStrategy","description":"集成投票策略 — 综合均线、MACD、RSI三个信号进行多数投票：≥2个信号看涨时做多，≥2个看空时平仓。降低单信号噪声，提高信号可靠性。","parameters":["symbol","min_votes","fast_period","slow_period","rsi_period"],"params_desc":{"min_votes":"最少赞成票数（默认2/3）"},"category":"ml","category_label":"机器学习","category_color":"#f59e0b","category_icon":"brain","tags":[